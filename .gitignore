# ------------------ Added to avoid committing secrets, local files and large binaries ------------------
# Environment and secret files
.env
.env.*
*.env
*.secret
credentials.json
secrets.json

# Local application properties (allow checked-in defaults but ignore local overrides)
application-local.properties
application-dev.properties
application-*.local.properties

# Keystores / certificates / keys
*.jks
*.keystore
*.p12
*.pem
*.crt
*.key
*.der

# Logs
/logs/
*.log
*.log.*

# Database files
*.db
*.sqlite
